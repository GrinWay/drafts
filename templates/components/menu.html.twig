		{%- block content -%}{%- endblock -%}
		<ul>
			{%- if is_granted('IS_AUTHENTICATED') -%}
				<li><a href="{{ path('app_admin_index', {}) }}">admin</a></li>
				<li><a href="{{ path('app_delete_current_user', {}) }}">Delete Account</a></li>
				<li><a href="{{ path('app_logout', {}) }}">Log out</a></li>
			{%- else -%}
