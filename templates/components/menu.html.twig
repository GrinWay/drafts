			<li><a href="{{ path('app_home_producttypes', {}) }}">Type</a></li>
			<li><a href="{{ path('app_home_home', {}) }}">home</a></li>
			<li><a href="{{ path('app_home_removeproduct', {}) }}">removeproduct</a></li>
